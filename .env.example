# Database
DB_HOST=db
DB_PORT=5433
DB_NAME=quiteup
DB_USER=quiteup_user
DB_PASSWORD=changeme

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=quiteup
RABBITMQ_PASSWORD=changeme

# JWT
JWT_SECRET=your-super-secret-key-at-least-32-characters!!
JWT_ISSUER=quite-up
JWT_AUDIENCE=quite-up-client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Hashids
HASHIDS_SALT=your-hashids-salt-change-this
HASHIDS_MIN_LENGTH=8

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=changeme
SMTP_FROM_NAME=Quite-Up
SMTP_FROM_EMAIL=noreply@example.com

# Dominio / URL base
# Dev local (HTTP puro, sem certificado):
#   DOMAIN=http://fedora-server
#   APP_URL=http://fedora-server
# Producao (HTTPS automatico via Let's Encrypt — aponte o DNS antes de subir):
#   DOMAIN=app.exemplo.com.br
#   APP_URL=https://app.exemplo.com.br
DOMAIN=http://fedora-server
APP_URL=http://fedora-server
